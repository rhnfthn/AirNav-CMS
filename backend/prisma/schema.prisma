// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============== ADMIN ==============
model Admin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

// ============== ABOUT ==============
model About {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  photoUrl    String?
  university  String?
  major       String?
  gpa         Float?
  updatedAt   DateTime @updatedAt

  @@map("about")
}

// ============== PROJECT ==============
model Project {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String   @db.Text
  content     String?  @db.Text
  techStack   String[] @default([])
  githubUrl   String?
  liveUrl     String?
  coverImage  String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([published])
  @@index([createdAt])
  @@map("projects")
}

// ============== CERTIFICATION ==============
model Certification {
  id            String  @id @default(uuid())
  title         String
  issuer        String
  year          Int
  credentialUrl String?
  imageUrl      String?

  @@map("certifications")
}

// ============== EXPERIENCE ==============
model Experience {
  id          String    @id @default(uuid())
  company     String
  position    String
  startDate   DateTime
  endDate     DateTime?
  description String    @db.Text
  createdAt   DateTime  @default(now())

  @@index([startDate])
  @@map("experiences")
}

// ============== TOOLS ==============
model Tool {
  id       String  @id @default(uuid())
  name     String
  iconUrl  String?
  category String

  @@map("tools")
}

// ============== CONTACT MESSAGE ==============
model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("contact_messages")
}

// ============== ATTACHMENTS (DB) ==============
model Attachment {
  id           String   @id @default(uuid())
  originalName String
  mimeType     String
  size         Int
  data         Bytes
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@map("attachments")
}

// ============== THEME SETTINGS (PUBLIC + ADMIN) ==============
enum ThemeScope {
  PUBLIC
  ADMIN

  @@map("theme_scope")
}

model ThemeSettings {
  id                     String      @id @default(uuid())
  scope                  ThemeScope  @default(PUBLIC) @map("scope")
  primaryBackgroundColor String      @map("primary_background_color")
  sidebarBackgroundColor String      @map("sidebar_background_color")
  headerBackgroundColor  String      @map("header_background_color")
  primaryTextColor       String      @map("primary_text_color")
  secondaryTextColor     String      @map("secondary_text_color")
  buttonColor            String      @map("button_color")
  borderColor            String      @map("border_color")

  // Admin Login Page customization (used by /admin/login)
  loginCardBgColor        String @default("#EAF4FB") @map("login_card_bg_color")
  loginCardBorderColor    String @default("#B8C6DB") @map("login_card_border_color")
  loginCardShadowColor    String @default("#B8C6DB") @map("login_card_shadow_color")

  loginLogoBgColor        String @default("#A7D3F5") @map("login_logo_bg_color")
  loginLogoBorderColor    String @default("#B8C6DB") @map("login_logo_border_color")
  loginLogoShadowColor    String @default("#B8C6DB") @map("login_logo_shadow_color")

  loginHeaderTextColor    String @default("#2C3E50") @map("login_header_text_color")
  loginContentTextColor   String @default("#64748B") @map("login_content_text_color")
  loginLabelTextColor     String @default("#2C3E50") @map("login_label_text_color")

  loginButtonLabel        String @default("Login") @map("login_button_label")
  loginButtonBgColor      String @default("#6FA8DC") @map("login_button_bg_color")
  loginButtonBorderColor  String @default("#B8C6DB") @map("login_button_border_color")
  loginButtonShadowColor  String @default("#B8C6DB") @map("login_button_shadow_color")

  loginBackToWebsiteText  String @default("← Back to website") @map("login_back_to_website_text")
  updatedAt              DateTime    @updatedAt @map("updated_at")

  @@unique([scope])
  @@map("theme_settings")
}

// ============== HOME LAYOUT SETTINGS (SINGLETON) ==============
enum HeroImagePosition {
  left
  right
  center

  @@map("hero_image_position")
}

enum HeroLayout {
  image_text
  text_image
  centered

  @@map("hero_layout")
}

model HomeLayoutSettings {
  id                   String            @id @default(uuid())
  heroImagePosition    HeroImagePosition @default(left) @map("hero_image_position")
  heroLayout           HeroLayout        @default(image_text) @map("hero_layout")
  sectionsOrder        Json              @map("sections_order")
  showFeaturedProjects Boolean           @default(true) @map("show_featured_projects")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  @@map("home_layout_settings")
}


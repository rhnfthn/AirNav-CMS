// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============== ADMIN ==============
model Admin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

// ============== ABOUT ==============
model About {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  photoUrl    String?
  updatedAt   DateTime @updatedAt

  @@map("about")
}

// ============== PROJECT ==============
model Project {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String   @db.Text
  content     String?  @db.Text
  techStack   String[] @default([])
  githubUrl   String?
  liveUrl     String?
  coverImage  String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([published])
  @@index([createdAt])
  @@map("projects")
}

// ============== CERTIFICATION ==============
model Certification {
  id            String  @id @default(uuid())
  title         String
  issuer        String
  year          Int
  credentialUrl String?
  imageUrl      String?

  @@map("certifications")
}

// ============== EXPERIENCE ==============
model Experience {
  id          String    @id @default(uuid())
  company     String
  position    String
  startDate   DateTime
  endDate     DateTime?
  description String    @db.Text
  createdAt   DateTime  @default(now())

  @@index([startDate])
  @@map("experiences")
}

// ============== TOOLS ==============
model Tool {
  id       String  @id @default(uuid())
  name     String
  iconUrl  String?
  category String

  @@map("tools")
}

// ============== CONTACT MESSAGE ==============
model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("contact_messages")
}
